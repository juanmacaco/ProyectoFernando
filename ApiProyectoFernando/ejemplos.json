{
  "info": {
    "name": "API Universo Dead Space",
    "description": "Ejemplos de solicitudes para la API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Naves",
      "item": [
        {
          "name": "Obtener todas las naves",
          "request": {
            "method": "GET",
            "url": "http://localhost:3000/api/naves"
          }
        },
        {
          "name": "Obtener nave por ID",
          "request": {
            "method": "GET",
            "url": "http://localhost:3000/api/naves/1"
          }
        },
        {
          "name": "Crear nueva nave",
          "request": {
            "method": "POST",
            "url": "http://localhost:3000/api/naves",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\"nombre\":\"Nueva Nave\",\"clase_nave_id\":1,\"faccion_id\":2,\"fabricante\":\"Fabricante XYZ\",\"armamento\":\"Láser\",\"capacidad_tripulacion\":\"50\"}"
            }
          }
        },
        {
          "name": "Actualizar nave",
          "request": {
            "method": "PUT",
            "url": "http://localhost:3000/api/naves/1",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\"nombre\":\"Nave Actualizada\"}"
            }
          }
        },
        {
          "name": "Eliminar nave",
          "request": {
            "method": "DELETE",
            "url": "http://localhost:3000/api/naves/1"
          }
        }
      ]
    },
